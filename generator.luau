local Generator = {}

local ParserTypes = require("parserTypes")
local GeneratorFunction = require("generatorFunction")

function Generator.generate(cpp_filename: string, out_types: string, decls: {ParserTypes.ParsedDecl})
    local file_definition_content = "// This file is generated by LuauParser. Do not edit manually.\n\n"
    local file_declaration_content = "-- This file is generated by LuauParser. Do not edit manually.\n\n"

    for _, decl in ipairs(decls) do
        if decl.kind == ParserTypes.DeclKind.Function then
            file_definition_content = file_definition_content .. GeneratorFunction.generate_function_luau_definition(decl)
            file_declaration_content = file_declaration_content .. GeneratorFunction.generate_function_luau_declaration(decl)
            print(file_declaration_content)
        elseif decl.kind == ParserTypes.DeclKind.Field then
            print("Generating field: " .. decl.name)
            -- Here you would generate the C++ code for the field declaration
            -- using decl.field_type and decl.attributes
        else
            print("Unknown declaration kind for: " .. decl.name)
        end
    end

    io.writefile(cpp_filename, file_definition_content)
    io.writefile(out_types, file_declaration_content)

end

return Generator