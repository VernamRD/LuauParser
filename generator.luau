local Generator = {}

local ParserTypes = require("parserTypes")
local GeneratorFunction = require("generatorFunction")

function Generator.generate(cpp_filename: string, out_types: string, decls: {ParserTypes.ParsedDecl})
    local file_content = "// This file is generated by LuauParser. Do not edit manually.\n\n"

    for _, decl in ipairs(decls) do
        if decl.kind == ParserTypes.DeclKind.Function then
            file_content = file_content .. GeneratorFunction.generate_function_luau_declaration(decl)
        elseif decl.kind == ParserTypes.DeclKind.Field then
            print("Generating field: " .. decl.name)
            -- Here you would generate the C++ code for the field declaration
            -- using decl.field_type and decl.attributes
        else
            print("Unknown declaration kind for: " .. decl.name)
        end
    end

    io.writefile(cpp_filename, file_content)
end

return Generator